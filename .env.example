# =====================================================
# LinguoLab — пример переменных окружения
# Скопируй в .env (для локалки) или .env.prod (для сервера)
# Никогда не коммить заполненный .env / .env.prod
# =====================================================

# === App ===
NODE_ENV=development
PORT=3000
APP_PUBLIC_URL=https://app-linguolab.muzaffarbahodir.uz
API_PUBLIC_URL=https://api-linguolab.muzaffarbahodir.uz
ADMIN_PUBLIC_URL=https://admin-linguolab.muzaffarbahodir.uz
CDN_PUBLIC_URL=https://cdn-linguolab.muzaffarbahodir.uz

# CORS: comma-separated список allowed origins
# Локально: добавить http://localhost:5173,http://localhost:3001
CORS_ALLOWED_ORIGINS=https://app-linguolab.muzaffarbahodir.uz,https://admin-linguolab.muzaffarbahodir.uz

# NextAuth (Admin) — секрет для подписи сессий
# openssl rand -hex 32
NEXTAUTH_SECRET=CHANGE_ME
NEXTAUTH_URL=https://admin-linguolab.muzaffarbahodir.uz
# Internal URL для Admin → API вызовов (внутри Docker сети)
API_URL=http://linguolab_api:3000

# === Database ===
# В compose API контейнер резолвит linguolab_postgres:5432 по сети linguolab_internal
DATABASE_URL=postgresql://linguolab:CHANGE_ME@linguolab_postgres:5432/linguolab
POSTGRES_PASSWORD=CHANGE_ME
REDIS_URL=redis://:CHANGE_ME@linguolab_redis:6379
REDIS_PASSWORD=CHANGE_ME

# === JWT ===
# openssl rand -hex 64
JWT_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# === Telegram ===
TELEGRAM_BOT_TOKEN=CHANGE_ME
TELEGRAM_BOT_USERNAME=linguolab_bot
# openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=CHANGE_ME
TELEGRAM_WEB_APP_URL=https://app-linguolab.muzaffarbahodir.uz

# === Cloudflare R2 ===
R2_ACCOUNT_ID=CHANGE_ME
R2_ACCESS_KEY_ID=CHANGE_ME
R2_SECRET_ACCESS_KEY=CHANGE_ME
R2_BUCKET_NAME=linguolab-files
R2_PUBLIC_URL=https://cdn-linguolab.muzaffarbahodir.uz
R2_ENDPOINT=https://CHANGE_ME.r2.cloudflarestorage.com

# === Payme (sandbox) ===
PAYME_MERCHANT_ID=
PAYME_MERCHANT_KEY=        # ключ для Basic Auth в webhook (= secret key кабинета Payme)
PAYME_SECRET_KEY=
PAYME_TEST_SECRET_KEY=
PAYME_CHECKOUT_URL=https://checkout.paycom.uz
PAYME_USE_SANDBOX=true

# === Click (sandbox) ===
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=
CLICK_ENDPOINT=https://my.click.uz/services/pay

# === Uzumbank (заглушка) ===
UZUMBANK_MERCHANT_ID=
UZUMBANK_SECRET_KEY=
UZUMBANK_ENDPOINT=

# === Soliq (sandbox ОФД) ===
# Документация: https://ofd.soliq.uz (требует регистрации юрлица)
# Sandbox: https://ofd-test.soliq.uz
SOLIQ_API_URL=https://ofd.soliq.uz
SOLIQ_SANDBOX_URL=https://ofd-test.soliq.uz
# true = sandbox режим (без реальных credentials возвращает stub-ответ)
SOLIQ_USE_SANDBOX=true
# Реквизиты юрлица (получить в кабинете Soliq)
SOLIQ_CLIENT_ID=              # ClientId (часто = ИНН)
SOLIQ_CLIENT_SECRET=          # ClientSecret / пароль API; если пусто — sandbox stub
SOLIQ_TIN=                    # ИНН организации (в теле чека)
SOLIQ_TERMINAL_ID=            # ID терминала кассы
SOLIQ_VAT_RATE=12             # ставка НДС % (Узбекистан = 12)

# === Налоги ===
# Ставка НДС % для чеков и расчёта vat_amount. 0 = режим без НДС (налог с оборота).
# По умолчанию 0 — безопасно, пока режим не подтверждён бухгалтером.
# Общий режим с НДС → 12.
VAT_RATE=0

# === Email (skip — TG основной канал) ===
SMTP_URL=
EMAIL_FROM=no-reply@linguolab.muzaffarbahodir.uz

# === Sentry ===
SENTRY_DSN=
SENTRY_DSN_WEB=

# === Admin ===
# Comma-separated list of Telegram user IDs that get SUPER_ADMIN role on first login
# Пример: SUPER_ADMIN_TELEGRAM_IDS=123456789,987654321
SUPER_ADMIN_TELEGRAM_IDS=

# === Misc ===
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
LOG_LEVEL=info
