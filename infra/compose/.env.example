# =============================================================
# LinguoLab — Production Environment Variables
# Copy this file to .env and fill all values before first deploy.
# NEVER commit .env to git.
# Generate secrets: openssl rand -hex 32
# =============================================================

# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=linguolab
POSTGRES_USER=linguolab
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# Full DSN used by Prisma (matches container service name)
DATABASE_URL=postgresql://linguolab:CHANGE_ME_strong_password_here@linguolab_postgres:5432/linguolab

# ─── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password_here
REDIS_URL=redis://:CHANGE_ME_redis_password_here@linguolab_redis:6379

# ─── NestJS API ───────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# JWT — sign access tokens (min 64 hex chars)
JWT_SECRET=CHANGE_ME_jwt_secret_minimum_64_chars_here_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_EXPIRES_IN=7d

# CORS — comma-separated allowed origins for browser clients
CORS_ALLOWED_ORIGINS=https://app-linguolab.muzaffarbahodir.uz,https://admin-linguolab.muzaffarbahodir.uz

# ─── Admin Panel (Next.js) ────────────────────────────────────
NEXTAUTH_URL=https://admin-linguolab.muzaffarbahodir.uz
NEXTAUTH_SECRET=CHANGE_ME_nextauth_secret_admin_32_chars_min

# Internal API URL (container-to-container)
NEXT_PUBLIC_API_URL=https://api-linguolab.muzaffarbahodir.uz
API_URL=http://linguolab_api:3000

# ─── Student Portal (Next.js) ─────────────────────────────────
NEXTAUTH_URL_PORTAL=https://app-linguolab.muzaffarbahodir.uz
NEXTAUTH_SECRET_PORTAL=CHANGE_ME_nextauth_secret_portal_32_chars_min

# ─── Telegram Bot ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=CHANGE_ME_from_botfather
# Public URL where Telegram will POST webhook events
TELEGRAM_WEBHOOK_URL=https://api-linguolab.muzaffarbahodir.uz/api/v1/telegram/webhook
# Admin Telegram user IDs (comma-separated) for bot alerts
TELEGRAM_ADMIN_IDS=

# ─── Sentry Error Tracking ────────────────────────────────────
SENTRY_DSN=https://CHANGE_ME@oXXXXX.ingest.sentry.io/XXXXXXX
# Optional: separate DSN per app
# SENTRY_DSN_ADMIN=...
# SENTRY_DSN_PORTAL=...

# ─── Payments ─────────────────────────────────────────────────
# Payme
PAYME_MERCHANT_ID=CHANGE_ME
PAYME_KEY=CHANGE_ME_payme_key
PAYME_TEST_KEY=CHANGE_ME_payme_test_key
PAYME_CALLBACK_URL=https://api-linguolab.muzaffarbahodir.uz/api/v1/payments/payme/callback

# Click
CLICK_MERCHANT_ID=CHANGE_ME
CLICK_SERVICE_ID=CHANGE_ME
CLICK_SECRET_KEY=CHANGE_ME_click_secret
CLICK_CALLBACK_URL=https://api-linguolab.muzaffarbahodir.uz/api/v1/payments/click/callback

# Uzum (Apelsin)
UZUM_MERCHANT_ID=CHANGE_ME
UZUM_SECRET_KEY=CHANGE_ME_uzum_secret
UZUM_CALLBACK_URL=https://api-linguolab.muzaffarbahodir.uz/api/v1/payments/uzum/callback

# ─── Soliq OFD (fiscal receipts) ─────────────────────────────
OFD_API_URL=https://ofd.soliq.uz
OFD_API_KEY=CHANGE_ME_soliq_api_key
OFD_TERMINAL_ID=CHANGE_ME
# false in production — enables real fiscal receipts
USE_SANDBOX=false

# ─── File Storage (S3-compatible) ────────────────────────────
STORAGE_ENDPOINT=https://s3.amazonaws.com
STORAGE_REGION=us-east-1
STORAGE_BUCKET=linguolab-uploads
STORAGE_ACCESS_KEY=CHANGE_ME
STORAGE_SECRET_KEY=CHANGE_ME

# ─── App URLs (for email links, QR codes, etc.) ──────────────
APP_URL=https://app-linguolab.muzaffarbahodir.uz
ADMIN_URL=https://admin-linguolab.muzaffarbahodir.uz
API_PUBLIC_URL=https://api-linguolab.muzaffarbahodir.uz
